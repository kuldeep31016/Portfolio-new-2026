# --- Contact form email (Nodemailer + Gmail) ---
# 1. Enable 2-Step Verification on the Gmail account.
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Copy these into a local .env.local file, and add them in Vercel
#    (Project → Settings → Environment Variables) for the deployed site.

SMTP_USER=iamkuldeepraj55@gmail.com
SMTP_PASS=your_16_character_app_password

# Optional — where messages are delivered (defaults to SMTP_USER)
CONTACT_TO=iamkuldeepraj55@gmail.com
